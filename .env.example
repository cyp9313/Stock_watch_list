# ─────────────────────────────────────────────────────────────────────
# Stock Watchlist + AI Daily Report — Environment Configuration
# ─────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in real values.
# Never commit the real ".env" file.
#
# Priority (highest first):
#   1. Process environment variables already set
#   2. Explicit env file path (load_project_env(explicit_path=...))
#   3. Project-root .env (this file)
#   4. Hard-coded defaults in code
#
# .env NEVER overrides variables already in the process environment.

# ── Frontend / Backend ───────────────────────────────────────────────
# Base URL of the Flask backend API
STOCK_API_BASE_URL=http://127.0.0.1:5000
# Development mode: "1" = auto-start Flask daemon (dev), "0" = production (external backend)
STOCK_DEV_MODE=1
# SQLite cache database path (default: <project_root>/stock_cache.db)
# STOCK_CACHE_DB_PATH=

# ── Login Security ───────────────────────────────────────────────────
# Max failed login attempts before lockout (min 3)
LOGIN_MAX_FAILURES=5
# Lockout duration in seconds (min 60)
LOGIN_LOCKOUT_SECONDS=900
# Failure counting window in seconds (min 60)
LOGIN_WINDOW_SECONDS=1800

# ── Report Jobs / Queue ──────────────────────────────────────────────
# SQLite path for the report job queue (default: <project_root>/daily_report_jobs.db)
# REPORT_JOB_DB=
# Global pending jobs limit
REPORT_MAX_GLOBAL_PENDING=50
# Per-user pending jobs limit (manual + scheduled shared)
REPORT_MAX_PENDING_PER_USER=5
# Global running jobs limit (for multi-worker readiness)
REPORT_MAX_GLOBAL_RUNNING=1
# Max hours a job can stay queued before being expired
REPORT_MAX_QUEUE_HOURS=6
# Per-user daily email report limit
REPORT_DAILY_LIMIT_PER_USER=3
# Max scheduled reports per user
REPORT_MAX_SCHEDULES_PER_USER=7
# Max send attempts per email job
REPORT_EMAIL_MAX_ATTEMPTS=3
# Days to retain completed/failed jobs before pruning
REPORT_JOB_RETENTION_DAYS=7
# Worker poll interval in seconds
REPORT_WORKER_POLL_SECONDS=3
# Timeout for report generation subprocess in seconds
STOCK_DAILY_REPORT_TIMEOUT=1800

# ── Download Rate Limit ──────────────────────────────────────────────
# Max concurrent downloads per user
REPORT_DOWNLOAD_MAX_ACTIVE_PER_USER=1
# Daily download limit per user
REPORT_DOWNLOAD_DAILY_LIMIT_PER_USER=5
# Global concurrent download limit
REPORT_DOWNLOAD_MAX_GLOBAL_ACTIVE=3

# ── SMTP Email ───────────────────────────────────────────────────────
REPORT_SMTP_HOST=smtp.163.com
REPORT_SMTP_PORT=465
REPORT_SMTP_USE_SSL=true
REPORT_SMTP_USER=your_account@163.com
REPORT_SMTP_FROM=your_account@163.com
# SMTP authorization code (NOT the mailbox login password)
REPORT_SMTP_AUTH_CODE=your_163_smtp_authorization_code
# SMTP connection timeout in seconds
REPORT_SMTP_TIMEOUT=30

# ── LLM Provider ─────────────────────────────────────────────────────
# Provider: auto, dashscope, deepseek, openai_compatible
LLM_PROVIDER=auto
# Model name (provider-specific)
QWEN_MODEL=deepseek-v4-flash
QWEN_RESEARCH_MODEL=deepseek-v4-flash
# DashScope (Alibaba Cloud) API key
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_RESEARCH_MODEL=deepseek-v4-flash
# Override raw API mode for Qwen-Agent
# QWEN_AGENT_USE_RAW_API=
# DeepSeek configuration
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=
# DEEPSEEK_MODEL_SERVER=https://api.deepseek.com/v1
# OpenAI-compatible endpoint
# OPENAI_API_KEY=
# OPENAI_MODEL_SERVER=
# QWEN_API_KEY=
# QWEN_MODEL_SERVER=
# Enable Qwen-Agent built-in web tools
ENABLE_BUILTIN_SERPER_WEB_TOOLS=false

# ── Search Provider ──────────────────────────────────────────────────
# Provider: auto, priority, searxng, serper, both
SEARCH_PROVIDER=both

# ── SearXNG ──────────────────────────────────────────────────────────
# SearXNG instance URL (leave empty to disable)
SEARXNG_URL=
# Search language: auto, en-US, zh-CN, etc.
SEARXNG_LANGUAGE=auto
# Time range: day, month, year
SEARXNG_TIME_RANGE=month
# Categories
SEARXNG_CATEGORIES=general,news
# Engines (comma-separated, leave empty for instance default)
# SEARXNG_ENGINES=
# Request timeout in seconds
SEARXNG_TIMEOUT=15
# Sleep between requests in seconds
SEARXNG_SLEEP_SECONDS=0.2

# ── Serper (Google Search API) ───────────────────────────────────────
SERPER_API_KEY=your_serper_api_key
# API base URL
SERPER_API_BASE=https://google.serper.dev
# Geographic and language settings
SERPER_GL=us
SERPER_HL=en
# Request timeout and rate limiting
SERPER_TIMEOUT=15
SERPER_SLEEP_SECONDS=0.2
# Search types: search, news, etc. (comma-separated)
SERPER_TYPES=search
# Evidence quality thresholds
SERPER_MIN_FINAL_EVIDENCE=10
SERPER_MIN_GRADE_AB=6
# Focus coverage: auto, always, never
SERPER_REQUIRED_FOCUS_COVERAGE=auto

# ── Article Fetch (SSRF-protected) ───────────────────────────────────
# Enable/disable article content fetching
ARTICLE_FETCH_ENABLED=true
# Max URLs to fetch per report
ARTICLE_FETCH_MAX_URLS=10
# Max characters to extract per article
ARTICLE_FETCH_MAX_CHARS=3500
# Fetch timeout per article in seconds
ARTICLE_FETCH_TIMEOUT=12
# Allowed ports (comma-separated, empty = 80,443 only)
# ARTICLE_FETCH_ALLOWED_PORTS=
# Max HTTP redirects (0-10)
ARTICLE_FETCH_MAX_REDIRECTS=4
# Max response body size in bytes
# ARTICLE_FETCH_MAX_RESPONSE_BYTES=
# Minimum article text length to keep
ARTICLE_MIN_TEXT_CHARS=800

# ── Evidence Quality ─────────────────────────────────────────────────
# Max evidence items with unknown dates
EVIDENCE_MAX_UNKNOWN_DATE=6
# Allow DashScope source objects in notes
ALLOW_DASHSCOPE_SOURCES_IN_NOTES=true
# Allow low-quality article records
ALLOW_LOW_QUALITY_ARTICLE_RECORDS=false

# ── StockAnalysis Scraper ────────────────────────────────────────────
# Enable/disable StockAnalysis.com scraping
STOCKANALYSIS_ENABLED=true

# ── Portfolio AI Reports ─────────────────────────────────────────────
# Portfolio reports share the same report worker and SMTP system as ticker reports.
PORTFOLIO_REPORT_TIMEOUT=1200
PORTFOLIO_RESEARCH_MAX_TICKERS=5
PORTFOLIO_RESEARCH_MIN_TICKERS=3
PORTFOLIO_RESEARCH_MAX_EVIDENCE_PER_TICKER=5
PORTFOLIO_ARTICLE_FETCH_MAX_URLS=8
PORTFOLIO_DOWNLOAD_MAX_ACTIVE_PER_USER=1
PORTFOLIO_DOWNLOAD_DAILY_LIMIT_PER_USER=3
PORTFOLIO_EMAIL_DAILY_LIMIT_PER_USER=2
PORTFOLIO_MAX_SCHEDULES_PER_USER=5
