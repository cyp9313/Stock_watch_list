# AI daily report model and research providers
LLM_PROVIDER=auto
QWEN_MODEL=deepseek-v4-flash
QWEN_RESEARCH_MODEL=deepseek-v4-flash
DASHSCOPE_RESEARCH_MODEL=deepseek-v4-flash
DASHSCOPE_API_KEY=your_dashscope_api_key
SERPER_API_KEY=your_serper_api_key
SEARXNG_URL=

# 163 Mail SMTP authorization code (not the mailbox login password)
REPORT_SMTP_HOST=smtp.163.com
REPORT_SMTP_PORT=465
REPORT_SMTP_USE_SSL=true
REPORT_SMTP_USER=your_account@163.com
REPORT_SMTP_FROM=your_account@163.com
REPORT_SMTP_AUTH_CODE=your_163_smtp_authorization_code

# Background email report limits and retention
REPORT_DAILY_LIMIT_PER_USER=3
REPORT_MAX_SCHEDULES_PER_USER=10
REPORT_EMAIL_MAX_ATTEMPTS=3
REPORT_JOB_RETENTION_DAYS=7
REPORT_WORKER_POLL_SECONDS=3
STOCK_DAILY_REPORT_TIMEOUT=1800
