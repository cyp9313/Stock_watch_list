-def _nearest_lookback(value: int) -> int:
-    """将非法 lookback 映射到最近允许档位（计划 §8.4）。"""
-    allowed = sorted(ALLOWED_LOOKBACK_DAYS)
-    return min(allowed, key=lambda a: abs(a - value))
