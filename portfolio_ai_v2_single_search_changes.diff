-)
-_AGGREGATOR_DOMAINS = frozenset({
-    "google.com", "news.google.com", "bing.com", "finance.google.com",
-    "yahoo.com", "finance.yahoo.com",
-})
-_COMMUNITY_DOMAINS = frozenset({
-    "reddit.com", "stocktwits.com", "twitter.com", "x.com",
-})
