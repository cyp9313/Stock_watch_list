-    if s.startswith("```"):
-        lines = s.splitlines()
-        if len(lines) > 2:
-            s = "\n".join(lines[1:-1]).strip()
-    start, end = s.find("{"), s.rfind("}")
-    if start < 0 or end <= start:
-        raise ValueError("Planner 未返回 JSON 对象")
-    chunk = s[start:end + 1]
-    parsed = json.loads(chunk)
-    if not isinstance(parsed, dict):
-        raise ValueError("Planner 输出不是对象")
-    return parsed
