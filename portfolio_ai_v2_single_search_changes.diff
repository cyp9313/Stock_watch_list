-def _dedup_queries(queries: list[str]) -> tuple[list[str], int]:
-    """去重 query 列表（保留首次出现顺序），返回 (unique, removed_count)。"""
-    seen: set[str] = set()
-    result: list[str] = []
-    removed = 0
-    for q in queries:
-        q_norm = q.strip().lower()
-        if q_norm in seen:
-            removed += 1
-        else:
-            seen.add(q_norm)
-            result.append(q.strip())
-    return result, removed
