-# site: 前缀匹配（计划 §8.4）
-_SITE_PREFIX_RE = re.compile(r"\bsite:([a-z0-9.-]+(?:\.[a-z]{2,}))\b", re.I)
-_SITE_PREFIX_START_RE = re.compile(r"^site:([a-z0-9.-]+(?:\.[a-z]{2,}))\s+", re.I)
