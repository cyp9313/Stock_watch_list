-        return "quote"
-
-    # Reference / Factsheet
-    if re.search(r"\b(fact\s*sheet|product\s+overview|fund\s+profile|etf\s+details|holdings\s+list)\b", text, re.I):
-        return "reference"
-
-    return "news_report"
-
-
-def classify_source_quality(
-    evidence_item: dict[str, Any],
-    meta: dict[str, Any] | None = None,
