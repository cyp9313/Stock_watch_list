-        return 0.5
-    ratio = rc / total_rc
-    # ratio >= 0.15 → 1.0; 0.10-0.15 → 0.8; 0.05-0.10 → 0.6; <0.05 → 0.4
-    if ratio >= 0.15:
-        return 1.0
-    if ratio >= 0.10:
-        return 0.8
-    if ratio >= 0.05:
-        return 0.6
-    return 0.4
