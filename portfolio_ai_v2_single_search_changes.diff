-                "lookback_days": lookback_int,
-                "lane": lane,
-                "ticker": None,
-                "event_need": event_need,
-                "question_id": question_id,
-                "preferred_domains": list(preferred_domains),
-                "required_entities": [],
-                "exclude_terms": [],
-                "use_news_vertical": use_news_vertical,
-                "scope": "macro",
-            })
-
-    return compiled
-
-
-def expand_official_lane_queries(
