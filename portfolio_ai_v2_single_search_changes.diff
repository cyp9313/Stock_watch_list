-    meta: dict[str, Any] | None = None,
-    corroboration_count: int = 0,
-) -> dict[str, Any]:
-    """计算单条证据的验证级别。
-
-    corroboration_count 由 event_clusterer 提供（同一 event_key 的来源数）。
