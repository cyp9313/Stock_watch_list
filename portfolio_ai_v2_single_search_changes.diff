-    # 默认：如果 URL 路径像产品页且无事件词 → reference_page
-    if path in {"", "/news"} or path.endswith("/news"):
-        # 新闻列表页，但无明确事件 → 当作 theme_event（宽松）
-        return "theme_event"
-    return "reference_page"
-
-
-def resolve_primary_entity(
-    result: dict[str, Any],
-    ticker: str | None,
-    meta: dict[str, Any],
-    *,
-    body: str = "",
-) -> dict[str, Any]:
-    """判断 result 的主要主体是否为 ticker。
